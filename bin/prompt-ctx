#!/usr/bin/env bun
import path from "path";
import { readFileSync, existsSync, statSync } from "fs";
import { Glob, type BunFile } from "bun";

const VERSION = "0.2.3";

// O(1) Lookups
const KNOWN_TEXT = new Set([
    ".js",
    ".jsx",
    ".ts",
    ".tsx",
    ".vue",
    ".svelte",
    ".html",
    ".css",
    ".json",
    ".md",
    ".mdx",
    ".yml",
    ".yaml",
    ".toml",
    ".ini",
    ".sql",
    ".prisma",
    ".graphql",
    ".sh",
    ".py",
    ".rb",
    ".php",
    ".rs",
    ".go",
    ".java",
    ".c",
    ".cpp",
    ".h",
    ".hpp",
    ".cs",
    ".kt",
    ".txt",
    ".csv",
    ".swift",
    ".dart",
    ".zig",
    ".lua",
    ".scala",
    ".hs",
    ".ex",
    ".erl",
    ".clj",
    ".ml",
    ".fs",
]);

const KNOWN_BINARIES = new Set([
    ".png",
    ".jpg",
    ".jpeg",
    ".gif",
    ".webp",
    ".svg",
    ".ico",
    ".tiff",
    ".woff",
    ".woff2",
    ".ttf",
    ".eot",
    ".mp4",
    ".mp3",
    ".wav",
    ".ogg",
    ".zip",
    ".tar",
    ".gz",
    ".7z",
    ".rar",
    ".pdf",
    ".exe",
    ".dll",
    ".so",
    ".dylib",
    ".wasm",
    ".jar",
    ".class",
    ".pyc",
    ".pck",
    ".ipa",
    ".apk",
    ".aab",
    ".dmg",
]);

// --- FILE TYPE CHECKER ---
async function checkIsTextFile(
    file: BunFile,
    basename: string,
): Promise<boolean> {
    // 0. Absolute security overrides
    if (basename.startsWith(".env")) return false; // Prevents key leaks

    const ext = path.extname(basename).toLowerCase();

    // 1. O(1) Fast Lanes (Catches ~95% of all real repository files)
    if (KNOWN_TEXT.has(ext)) return true;
    if (KNOWN_BINARIES.has(ext)) return false;

    // 2. The standard MIME fallback (for standard web assets missed above)
    const baseType = file.type.split(";")[0];
    if (
        baseType.startsWith("text/") ||
        baseType.endsWith("/json") ||
        baseType.endsWith("/xml")
    ) {
        return true;
    }

    // 3. The "Git 4K" Sniff (Only triggered for weird mystery files e.g. 'Dockerfile')
    try {
        const chunk = await file.slice(0, 4096).bytes();
        if (chunk.length === 0) return true;

        for (let i = 0; i < chunk.length; i++) {
            if (chunk[i] === 0) return false; // Immediate Git-style binary kill
        }

        return true;
    } catch {
        return false; // Unreadable = unsafe for LLM context
    }
}

// Single source of truth for resolving files + directory indexes
function resolveExtensionCandidate(fullPath: string): string | null {
    const candidates = [
        fullPath,
        `${fullPath}.ts`,
        `${fullPath}.tsx`,
        `${fullPath}.js`,
        `${fullPath}.jsx`,
        `${fullPath}.vue`,
        `${fullPath}.svelte`,
        path.join(fullPath, "index.ts"),
        path.join(fullPath, "index.tsx"),
        path.join(fullPath, "index.js"),
        path.join(fullPath, "index.jsx"),
        path.join(fullPath, "index.vue"),
        path.join(fullPath, "index.svelte"),
    ];

    for (const candidate of candidates) {
        try {
            if (statSync(candidate).isFile()) {
                return candidate;
            }
        } catch {
            continue;
        }
    }
    return null;
}

// --- PATH NORMALIZER ---
function normalizePath(p: string) {
    const absolute = path.resolve(p);
    let rel = path.relative(process.cwd(), absolute);
    return rel.replace(/\\/g, "/");
}

type TsConfigPaths = Record<string, string[]>;

const tsConfigCache = new Map<
    string,
    Promise<{ paths: TsConfigPaths; absoluteBaseUrl: string }>
>();

function findNearestTsConfig(startDir: string): string | null {
    let currentDir = path.resolve(startDir);

    while (true) {
        for (const filename of ["tsconfig.json", "jsconfig.json"]) {
            const configPath = path.join(currentDir, filename);
            if (existsSync(configPath)) {
                return configPath;
            }
        }
        const parentDir = path.dirname(currentDir);
        if (parentDir === currentDir) break;
        currentDir = parentDir;
    }
    return null;
}

async function loadTsConfigPaths(
    startDir: string = process.cwd(),
): Promise<{ paths: TsConfigPaths; absoluteBaseUrl: string }> {
    const configPath = findNearestTsConfig(startDir);

    if (!configPath) {
        return { paths: {}, absoluteBaseUrl: process.cwd() };
    }

    // Cache by the actual tsconfig path (prevents duplicate I/O)
    if (tsConfigCache.has(configPath)) {
        return tsConfigCache.get(configPath)!;
    }

    const promise = (async () => {
        try {
            const config = (await Bun.file(configPath).json()) as any;
            const compilerOptions = config.compilerOptions || {};
            const rawBaseUrl = compilerOptions.baseUrl || ".";

            return {
                paths: compilerOptions.paths || {},
                // Correctly resolve baseUrl relative to the tsconfig location
                absoluteBaseUrl: path.resolve(
                    path.dirname(configPath),
                    rawBaseUrl,
                ),
            };
        } catch {
            return {
                paths: {},
                absoluteBaseUrl: path.dirname(configPath),
            };
        }
    })();

    tsConfigCache.set(configPath, promise);
    return promise;
}

async function resolveTsConfigAlias(
    importPath: string,
    startDir: string,
): Promise<string | null> {
    const { paths, absoluteBaseUrl } = await loadTsConfigPaths(startDir);
    if (Object.keys(paths).length === 0) return null;

    const sortedAliases = Object.entries(paths).sort(
        ([a], [b]) => b.length - a.length,
    );

    for (const [alias, targets] of sortedAliases) {
        const aliasPattern = alias.replace(/\*/g, "(.*)");
        const regex = new RegExp(
            `^${aliasPattern.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}$`,
        );

        const match = importPath.match(regex);
        if (!match) continue;

        const wildcardValue = match[1] || "";
        const normalizedTargets = Array.isArray(targets) ? targets : [targets];

        for (const target of normalizedTargets) {
            const resolvedTarget = target.replace("*", wildcardValue);
            const fullPath = path.resolve(absoluteBaseUrl, resolvedTarget);

            const found = resolveExtensionCandidate(fullPath);
            if (found) return found;
        }
    }

    return null;
}

// --- MAIN PLUGIN ---
const enhancedResolverPlugin = {
    name: "enhanced-resolver",
    setup(build: any) {
        build.onResolve({ filter: /.*/ }, async (args: any) => {
            if (!args.path.includes("/") && !args.path.startsWith(".")) {
                return;
            }

            const startDir = args.importer
                ? path.dirname(args.importer)
                : process.cwd();

            // 1. Resolve tsconfig aliases (highest priority)
            const tsResolved = await resolveTsConfigAlias(args.path, startDir);
            if (tsResolved) {
                return { path: tsResolved };
            }

            // 2. Dynamic import handling (React.lazy, await import(), code splitting)
            if (args.kind === "dynamic-import") {
                let resolvedPath: string | null = null;

                if (args.path.startsWith(".")) {
                    resolvedPath = path.resolve(startDir, args.path);
                } else if (args.path.startsWith("/")) {
                    resolvedPath = path.join(process.cwd(), args.path);
                }

                if (resolvedPath) {
                    const found = resolveExtensionCandidate(resolvedPath);
                    if (found) return { path: found };
                }
            }

            // 3. Existing Vite-style absolute path handling
            if (
                path.isAbsolute(args.path) &&
                args.path.startsWith(process.cwd())
            ) {
                if (existsSync(args.path)) return { path: args.path };

                const relative = path.relative(process.cwd(), args.path);
                const publicPath = path.join(process.cwd(), "public", relative);
                if (existsSync(publicPath)) return { path: publicPath };

                const assetsPath = path.join(process.cwd(), "assets", relative);
                if (existsSync(assetsPath)) return { path: assetsPath };

                return { path: args.path, namespace: "ignore" };
            }

            // 4. Static absolute root imports (e.g. import X from "/src/components/Header")
            if (args.path.startsWith("/")) {
                const absolute = path.join(process.cwd(), args.path);
                const found = resolveExtensionCandidate(absolute);
                if (found) return { path: found };
            }

            return;
        });

        build.onLoad({ filter: /.*/, namespace: "ignore" }, () => ({
            contents: "",
        }));
    },
};

type GitignoreRule = {
    pattern: string;
    isNegation: boolean;
};

function parseGitignore(content: string, dir: string): GitignoreRule[] {
    let relDir = path.relative(process.cwd(), dir).replace(/\\/g, "/");
    if (relDir && !relDir.endsWith("/")) relDir += "/";

    return content
        .split(/\r?\n/)
        .map((line) => line.trim())
        .filter((line) => line && !line.startsWith("#"))
        .reverse()
        .map((line) => {
            const isNegation = line.startsWith("!");
            if (isNegation) line = line.slice(1);
            if (line.endsWith("/")) line = line.slice(0, -1);

            if (line.endsWith("/*")) {
                line = line.slice(0, -2);
            }

            let processed = line;
            if (!line.startsWith("/")) {
                if (!line.includes("/") && line.includes("*")) {
                    processed = "**/" + line;
                } else if (line.includes("/") && !line.startsWith("**")) {
                    processed = "/" + relDir + line;
                }
            } else {
                processed = "/" + relDir + line.slice(1);
            }

            return {
                pattern: processed,
                isNegation,
            };
        });
}

function matchesGlob(filePath: string, pattern: string): boolean {
    let globPattern = pattern;
    let isAnchored = false;

    // Handle root-anchored patterns
    if (globPattern.startsWith("/")) {
        globPattern = globPattern.slice(1);
        isAnchored = true;
    }

    try {
        if (globPattern.includes("*")) {
            const glob = new Glob(globPattern);
            if (glob.match(filePath)) return true;
        }
    } catch {}

    // Fallback for simple non-glob patterns
    if (isAnchored) {
        return (
            filePath === globPattern || filePath.startsWith(globPattern + "/")
        );
    } else {
        return (
            filePath === globPattern ||
            filePath.startsWith(globPattern + "/") ||
            filePath.includes("/" + globPattern + "/") ||
            filePath.endsWith("/" + globPattern)
        );
    }
}

const gitignoreCache = new Map<string, GitignoreRule[]>();

/**
 * Collects .gitignore rules from the file's directory up to root.
 * Returns rules in order: deepest first → root last.
 */
function getGitignoreRulesForFile(filePath: string): GitignoreRule[] {
    const rules: GitignoreRule[] = [];
    let currentDir = path.dirname(path.resolve(filePath));
    const rootDir = process.cwd().toLowerCase();

    while (currentDir.toLowerCase().startsWith(rootDir)) {
        const cacheKey = currentDir.toLowerCase();

        if (!gitignoreCache.has(cacheKey)) {
            const gitignorePath = path.join(currentDir, ".gitignore");
            if (existsSync(gitignorePath)) {
                const content = readFileSync(gitignorePath, "utf8");
                gitignoreCache.set(
                    cacheKey,
                    parseGitignore(content, currentDir),
                );
            } else {
                gitignoreCache.set(cacheKey, []);
            }
        }

        rules.push(...gitignoreCache.get(cacheKey)!);

        if (currentDir.toLowerCase() === rootDir) break;
        currentDir = path.dirname(currentDir);
    }

    return rules;
}

function isExcluded(filePath: string, cliExcludes: string[]): boolean {
    const normPath = filePath.replace(/\\/g, "/");

    // Hard safety nets
    if (normPath.includes("node_modules/") || normPath.includes(".git/")) {
        return true;
    }

    // CLI has highest priority
    for (const pattern of cliExcludes) {
        if (matchesGlob(normPath, pattern)) return true;
    }

    // Gitignore rules (deepest first)
    const rules = getGitignoreRulesForFile(normPath);

    for (const rule of rules) {
        if (rule.isNegation && matchesGlob(normPath, rule.pattern)) {
            return false;
        }
        if (!rule.isNegation && matchesGlob(normPath, rule.pattern)) {
            return true;
        }
    }

    return false;
}

// --- CSS @IMPORT CRAWLER ---
async function crawlCssImports(
    filePath: string,
    baseExcludes: string[],
    visited = new Set<string>(),
) {
    const normalizedFilePath = normalizePath(filePath);
    if (visited.has(normalizedFilePath)) return visited;
    visited.add(normalizedFilePath);

    const file = Bun.file(normalizedFilePath);
    if (!(await file.exists())) return visited;

    const content = await file.text();
    const importRegex = /@import\s+(?:url\()?['"]([^'"]+)['"]\)?/g;
    let match;

    while ((match = importRegex.exec(content)) !== null) {
        let importPath = match[1];

        // Immediately ignore web protocols and embedded data URIs
        if (/^(https?:|data:|ftp:|file:)/i.test(importPath)) continue;

        if (importPath.startsWith("/")) {
            importPath = path.join(process.cwd(), importPath);
        } else {
            importPath = path.resolve(
                path.dirname(normalizedFilePath),
                importPath,
            );
        }

        const normImportPath = normalizePath(importPath);
        if (!isExcluded(normImportPath, baseExcludes)) {
            await crawlCssImports(normImportPath, baseExcludes, visited);
        }
    }

    return visited;
}

import { statSync, existsSync, renameSync, readFileSync } from "fs";

// --- GLOB OPTIMIZER ---
function extractGlobBase(pattern: string): string {
    const globChars = ["*", "?", "[", "{"];
    let firstGlobIndex = -1;
    for (const char of globChars) {
        const idx = pattern.indexOf(char);
        if (idx !== -1 && (firstGlobIndex === -1 || idx < firstGlobIndex)) {
            firstGlobIndex = idx;
        }
    }
    if (firstGlobIndex === -1) return ".";

    const prefix = pattern.substring(0, firstGlobIndex);
    const baseDir = path.dirname(prefix + "a"); // Ensure we stop at the last slash
    return baseDir === "." ? "." : baseDir;
}

// --- TYPESCRIPT .d.ts CRAWLER ---
async function crawlTypeImports(
    filePath: string,
    baseExcludes: string[],
    visited = new Set<string>(),
) {
    const normPath = normalizePath(filePath);
    if (visited.has(normPath)) return visited;
    visited.add(normPath);

    const file = Bun.file(normPath);
    if (!(await file.exists())) return visited;

    const content = await file.text();
    // Catch `import type ... from "..."`, `import { type ... } from "..."`, `export type ... from "..."`
    const importRegex =
        /(?:import|export)\s+.*?(?:type\s+[^'"]*)?from\s+['"]([^'"]+)['"]/g;

    let match;
    while ((match = importRegex.exec(content)) !== null) {
        const importPath = match[1];
        if (!importPath.startsWith(".")) continue; // Ignore package imports

        const resolvedBase = path.resolve(path.dirname(normPath), importPath);

        const candidates = [
            resolvedBase + ".ts",
            resolvedBase + ".d.ts",
            resolvedBase + ".tsx",
            resolvedBase + ".mts",
            resolvedBase + ".d.mts",
            resolvedBase + ".cts",
            resolvedBase + ".d.cts",
            path.join(resolvedBase, "index.ts"),
            path.join(resolvedBase, "index.d.ts"),
        ];

        for (const candidate of candidates) {
            if (existsSync(candidate)) {
                const normCandidate = normalizePath(candidate);
                if (
                    !isExcluded(normCandidate, baseExcludes) &&
                    !visited.has(normCandidate)
                ) {
                    await crawlTypeImports(
                        normCandidate,
                        baseExcludes,
                        visited,
                    );
                }
                break; // Found the matching file, stop checking candidates
            }
        }
    }
    return visited;
}

// --- MAIN ASSEMBLER ---
async function assembleLlmContext(
    includes: string[],
    baseExcludes: string[],
    outputFile: string,
) {
    try {
        let inputs = new Set<string>();

        // Normalize CLI exclusions using Gitignore-style glob expansion
        const normalizedBaseExcludes = baseExcludes.map((pattern) => {
            if (
                !pattern.startsWith("/") &&
                !pattern.includes("/") &&
                pattern.includes("*")
            ) {
                return "**/" + pattern;
            }
            return pattern;
        });

        // Normalize output path for reliable self-exclusion
        const normOutPath = normalizePath(outputFile);
        const outBase = path.basename(normOutPath, path.extname(normOutPath));
        const outDir = path.dirname(normOutPath);

        // Build safe self-excludes that work even when output is in a subdirectory
        const selfExcludes = [
            `/${normOutPath}`,
            `/${outDir === "." ? "" : outDir + "/"}${outBase}*${path.extname(normOutPath)}`,
            `/${outDir === "." ? "" : outDir + "/"}${outBase}*.txt`,
        ];

        const globalExcludes = [...normalizedBaseExcludes, ...selfExcludes];

        // 1. Expand input globs and add explicit files
        for (const pattern of includes) {
            if (pattern.includes("*")) {
                const baseDir = extractGlobBase(pattern);
                const relPattern = path
                    .relative(baseDir, pattern)
                    .replace(/\\/g, "/");
                const glob = new Glob(relPattern);
                // Important: Bun's glob matching logic needs the results mapped correctly
                for (const file of glob.scanSync(baseDir)) {
                    inputs.add(normalizePath(path.join(baseDir, file)));
                }
            } else {
                try {
                    const stat = statSync(pattern);
                    if (stat.isDirectory()) {
                        const glob = new Glob("**/*");
                        for (const file of glob.scanSync(pattern)) {
                            const fullPath = normalizePath(
                                path.join(pattern, file),
                            );
                            // Gatekeeper: Never let node_modules or excluded files enter the Set!
                            if (!isExcluded(fullPath, globalExcludes)) {
                                inputs.add(fullPath);
                            }
                        }
                    } else {
                        inputs.add(normalizePath(pattern));
                    }
                } catch (error: any) {
                    if (error.code === "ENOENT") {
                        console.error(
                            `❌ Error: File or directory not found: '${pattern}'`,
                        );
                    } else {
                        console.error(
                            `❌ Error accessing '${pattern}':`,
                            error.message || error,
                        );
                    }
                    process.exit(1);
                }
            }
        }

        // 2. Initial scrub
        for (const file of Array.from(inputs)) {
            if (isExcluded(file, globalExcludes)) {
                inputs.delete(file);
            }
        }

        // 3. Identify entrypoints safe for Bun.build mapping
        const buildableExts = new Set([".js", ".jsx", ".ts", ".tsx", ".html"]);
        const entrypoints = Array.from(inputs).filter((f) =>
            buildableExts.has(path.extname(f).toLowerCase()),
        );

        // 4. Let Bun trace the AST dependency tree for code files
        if (entrypoints.length > 0) {
            try {
                const result = await Bun.build({
                    entrypoints: entrypoints,
                    target: "bun",
                    packages: "external",
                    metafile: true,
                    plugins: [enhancedResolverPlugin],
                });

                if (result.success && result.metafile) {
                    const metaStr = result.metafile;
                    const meta =
                        typeof metaStr === "string"
                            ? JSON.parse(metaStr)
                            : metaStr;

                    Object.keys(meta.inputs || {}).forEach((f) => {
                        const normPath = normalizePath(f);
                        if (!isExcluded(normPath, globalExcludes))
                            inputs.add(normPath);
                    });
                } else if (!result.success) {
                    console.warn(
                        "⚠️ Bun had issues tracing some AST dependencies:",
                        result.logs,
                    );
                }
            } catch (buildError: any) {
                console.warn(
                    `⚠️ AST Tracing failed: ${buildError.message || "Bundle failed"}. Proceeding with matched files only.`,
                );
            }

            // 4.5. TS Type Crawling (recover ghosted .d.ts files from imports)
            const typeableExts = new Set([".ts", ".tsx", ".vue"]);
            const tsFiles = Array.from(inputs).filter((f) =>
                typeableExts.has(path.extname(f).toLowerCase()),
            );

            const globalTypeVisited = new Set<string>();
            for (const file of tsFiles) {
                const typeDeps = await crawlTypeImports(
                    file,
                    globalExcludes,
                    globalTypeVisited,
                );
                typeDeps.forEach((dep) => {
                    if (!isExcluded(dep, globalExcludes)) inputs.add(dep);
                });
            }
        }

        // 5. CSS Scan
        const initialFiles = Array.from(inputs);
        const globalCssVisited = new Set<string>();
        for (const file of initialFiles) {
            if (file.endsWith(".css")) {
                const cssDeps = await crawlCssImports(
                    file,
                    globalExcludes,
                    globalCssVisited,
                );
                cssDeps.forEach((dep) => {
                    if (!isExcluded(dep, globalExcludes)) inputs.add(dep);
                });
            }
        }

        let processedCount = 0;

        // 6. Sort inputs alphabetically for deterministic output
        const sortedInputs = Array.from(inputs).sort();

        // 7. Read and append files safely via streaming
        const tmpOutputFile = outputFile + ".tmp";
        const writer = Bun.file(tmpOutputFile).writer();
        const hasher = new Bun.CryptoHasher("sha256");

        try {
            const fileHeader = `// Context Assembled via AST/Glob Trace\n\n`;
            writer.write(fileHeader);
            hasher.update(fileHeader);

            for (const filePath of sortedInputs) {
                const file = Bun.file(filePath);
                if (await file.exists()) {
                    const basename = path.basename(filePath);

                    // Safe check: Is it text based on mime-type and contents?
                    const isTextFile = await checkIsTextFile(file, basename);

                    let header = `// ==========================================\n`;
                    header += `// File: ${filePath}\n`;
                    header += `// ==========================================\n\n`;

                    if (isTextFile) {
                        writer.write(header);
                        hasher.update(header);

                        // True O(1) Memory Streaming
                        for await (const chunk of file.stream()) {
                            writer.write(chunk);
                            hasher.update(chunk);
                        }

                        writer.write("\n\n");
                        hasher.update("\n\n");
                    } else {
                        header += `// [BINARY, EXCLUDED, OR NON-TEXT FILE OMITTED]\n\n`;
                        writer.write(header);
                        hasher.update(header);
                    }
                    processedCount++;
                }
            }
        } finally {
            await writer.end();
        }

        // 8. Compute SHA
        const shortSha = hasher.digest("hex").substring(0, 8);

        // 9. Inject SHA into filename
        const extIndex = outputFile.lastIndexOf(".");
        const finalOutputFile =
            extIndex !== -1
                ? `${outputFile.substring(0, extIndex)}-${shortSha}${outputFile.substring(extIndex)}`
                : `${outputFile}-${shortSha}`;

        // 10. Atomic Swap
        renameSync(tmpOutputFile, finalOutputFile);

        console.log(
            `✅ Successfully assembled ${processedCount} files into ${finalOutputFile}`,
        );
    } catch (error: any) {
        console.error(`❌ Error generating context: ${error.message || error}`);
        process.exit(1);
    }
}

// --- CLI ARGUMENT PARSER ---
const args = Bun.argv.slice(2);

if (args.length === 0 || args.includes("--help") || args.includes("-h")) {
    console.log(`
Usage: prompt-ctx <includes...> [options]

The Bun-native, AST-aware context packer.

Options:
  --out <file>        Output filename (default: llm-context.txt)
                      The final file will include an 8-char SHA
  --exclude <globs>   Additional patterns to ignore (merged with .gitignore)
  --help, -h          Show this help message
  --version, -v       Show version

Examples:
  prompt-ctx src/main.ts
  prompt-ctx src/main.ts --out my-feature.txt
  prompt-ctx src/**/* --exclude "**/*.test.*"
`);
    process.exit(0);
}

if (args.includes("--version") || args.includes("-v")) {
    console.log(`prompt-ctx ${VERSION}`);
    process.exit(0);
}

const includes: string[] = [];
const excludes: string[] = [];
let outputFile = "llm-context.txt";

for (let i = 0; i < args.length; i++) {
    const arg = args[i];

    if (arg === "--exclude") {
        while (i + 1 < args.length && !args[i + 1].startsWith("-")) {
            excludes.push(args[i + 1]);
            i++;
        }
        continue;
    }

    if (arg === "--out") {
        if (i + 1 < args.length) {
            outputFile = args[i + 1];
            i++;
        }
        continue;
    }

    if (!arg.startsWith("-")) {
        includes.push(arg);
    }
}

if (includes.length === 0) {
    console.error("❌ You must specify at least one entry file or pattern.");
    process.exit(1);
}

// Execute
assembleLlmContext(includes, excludes, outputFile);
